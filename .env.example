# ══════════════════════════════════════════════════════════════
# POLYMARKET INTELLIGENCE SYSTEM — Environment Configuration
# ══════════════════════════════════════════════════════════════

# Trading
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_WALLET_ADDRESS=0x...
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_RELAYER_API_KEY=
SIGNATURE_TYPE=0
EXECUTION_MODE=paper
STARTING_CAPITAL=300
PAPER_TRADING=true

# AI Models
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MIROFISH_AGENTS=20
AI_ENSEMBLE_TIMEOUT=30

# Data
NEWSAPI_KEY=
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
ADSBX_RAPIDAPI_KEY=

# Strategies (enable/disable each)
STRATEGY_ENTROPY=true
STRATEGY_AVELLANEDA=true
STRATEGY_ARB=true
STRATEGY_ENSEMBLE=true
STRATEGY_JET=true
STRATEGY_COPY=true
STRATEGY_THETA=true

# Quant parameters
ENTROPY_THRESHOLD=0.08
ENTROPY_EFFICIENCY_MAX=0.35
KELLY_FRACTION=0.25
AS_GAMMA=0.1
AS_KAPPA=1.5
AS_SESSION_HOURS=24
VPIN_PAUSE_THRESHOLD=0.70
MIN_ARB_EDGE=0.015

# Copy trading
COPY_TARGETS=RN1_WALLET,WALLET2
COPY_RATIO=0.10
COPY_MAX_SIZE_USDC=75
COPY_CONFLUENCE_REQUIRED=false

# Risk
MAX_PORTFOLIO_EXPOSURE=0.80
MAX_SINGLE_MARKET_PCT=0.15
MAX_DAILY_LOSS_PCT=0.10
MAX_TRADE_SIZE_USDC=150
MIN_BALANCE_USDC=10

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
JET_MANUAL_CONFIRM=true

# VPN / Proxy (gluetun SOCKS5 — ProtonVPN WireGuard)
PROXY_URL=socks5://127.0.0.1:1080
VPN_CHECK_URL=https://ipinfo.io/json
VPN_REQUIRED=true
VPN_CHECK_INTERVAL_SECONDS=300

# ProtonVPN WireGuard config
# Generate at: https://account.protonvpn.com/downloads#wireguard-configuration
# ROTATE YOUR KEY if it was ever exposed!
VPN_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.2.0.2/32
WIREGUARD_PUBLIC_KEY=
VPN_ENDPOINT_IP=
VPN_ENDPOINT_PORT=51820
DNS_ADDRESS=10.2.0.1
